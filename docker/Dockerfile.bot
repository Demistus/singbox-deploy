FROM python:3.11-slim

RUN apt-get update && apt-get install -y \
    curl \
    docker.io \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

RUN pip install python-telegram-bot==20.7 qrcode==7.4.2 Pillow==10.1.0

COPY configs/bot/telegram_bot.py /app/telegram_bot.py

VOLUME ["/app/data", "/opt/singbox-stats"]

CMD ["python", "-u", "telegram_bot.py"]
